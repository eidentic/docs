---
// Force server-side rendering for dynamic subdomain support
export const prerender = false;

import { getArticles, getCategories, getHelpCenterConfig, getFaqs, getFolders } from '../lib/localData';
import { buildPublicUrl } from '../lib/site-url';
import BaseLayout from '../layouts/BaseLayout.astro';
import HelpCenterHome from '../components/HelpCenterHome.tsx';
import CategoryPageWrapper from '../components/CategoryPageWrapper.tsx';
import ArticlePageWrapper from '../components/ArticlePageWrapper.tsx';

const projectId = 'local';
const apiSpecUrl: string | null = null;
const [articles, categories, faqs, configData, folders] = await Promise.all([
  getArticles(), getCategories(), getFaqs(), getHelpCenterConfig(), getFolders(),
]);

const { slug } = Astro.params;

// Helper: match category by slug, id, or name-derived slug
const findCategory = (s: string) => categories.find(c =>
  c.id === s ||
  c.name?.toLowerCase().replace(/\s+/g, '-') === s ||
  c.name?.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') === s
);

// Try folder first (must have a name to be valid), then category, then article
const folder: any = folders.find((f: any) => f.slug === slug && f.name);
const category: any = !folder ? findCategory(slug!) : null;
const article: any = !folder && !category ? articles.find((a: any) => a.slug === slug) : null;

if (!folder && !category && !article) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

// Non-default folders redirect to their first article instead of showing the home page
if (folder && !folder.is_default) {
  // Find categories belonging to this folder, sorted by display_order
  const folderCategories = categories
    .filter((c: any) => c.folder_id === folder.id)
    .sort((a: any, b: any) => (a.display_order ?? 999) - (b.display_order ?? 999));

  // Find the first article across those categories (in category order)
  let firstArticle: any = null;
  for (const cat of folderCategories) {
    const catArticles = articles.filter((a: any) => a.category_id === cat.id);
    if (catArticles.length > 0) {
      firstArticle = catArticles[0];
      break;
    }
  }

  if (firstArticle) {
    return Astro.redirect(`/${folder.slug}/article/${firstArticle.slug}`, 302);
  }
  // If no articles found, fall through and render the home page for this folder
}

// Article helpers (only needed when article matched)
const getCategoryName = (categoryId: string | null) => {
  if (!categoryId) return 'General';
  return categories.find((c: any) => c.id === categoryId)?.name || 'General';
};
const formattedDate = article?.created_at
  ? new Date(article.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : '';
const articleExcerpt = article?.excerpt || article?.title || '';
const categoryName = article ? getCategoryName(article.category_id) : '';
const articleUrl = article
  ? buildPublicUrl(Astro.request, Astro.url, `/article/${article.slug}`, configData)
  : '';

const config = configData;
---

{folder && (
  <BaseLayout 
    title={`${folder.name} - ${config.portal_name}`}
    description={folder.description || `Browse ${folder.name} articles`}
    config={config}
    projectId={projectId}
    folders={folders}
    ogImage={config.og_image_url ?? undefined}
    ogType="website"
  >
    <HelpCenterHome
      client:only="react"
      transition:persist="help-center-home"
      config={config}
      articles={articles}
      categories={categories}
      folders={folders}
      faqs={faqs}
      projectId={projectId}
      initialFolderId={folder.id}
    />
  </BaseLayout>
)}

{category && (
  <BaseLayout
    title={`${category.name} - ${config.portal_name}`}
    description={category.description || `Browse ${category.name} articles`}
    config={config}
    projectId={projectId}
    folders={folders}
  >
    <CategoryPageWrapper
      client:only="react"
      transition:persist="category-page-wrapper"
      config={config}
      category={category}
      articles={articles.filter((a: any) => a.category_id === category.id)}
      allCategories={categories}
      allArticles={articles}
      projectId={projectId}
      folders={folders}
    />
  </BaseLayout>
)}


{article && (
  <BaseLayout
    title={article.title}
    description={articleExcerpt}
    config={config}
    projectId={projectId}
    folders={folders}
    ogImage={config.og_image_url ?? undefined}
    ogType="article"
    article={{
      publishedTime: article.created_at,
      modifiedTime: article.updated_at,
      author: config.portal_name,
      section: categoryName !== 'General' ? categoryName : undefined
    }}
  >
    <ArticlePageWrapper
      client:only="react"
      transition:persist="article-page-wrapper"
      config={config}
      article={article}
      categories={categories}
      allArticles={articles}
      categoryName={categoryName}
      articleUrl={articleUrl}
      formattedDate={formattedDate}
      projectId={projectId}
      folders={folders}
      apiSpecUrl={apiSpecUrl}
    />
  </BaseLayout>
)}
