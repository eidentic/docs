# ─────────────────────────────────────────────────────────────
# Eidentic Docs — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# Your backend API base URL (no trailing slash)
PUBLIC_API_URL=https://your-api.example.com/api

# Public project / workspace ID to load content for
PUBLIC_PROJECT_ID=your-project-uuid-here

# Site metadata
PUBLIC_SITE_TITLE=Eidentic Docs
PUBLIC_SITE_DESCRIPTION=Documentation for Eidentic

# Server runtime
HOST=0.0.0.0
PORT=4321
FEEDBACK_DB_PATH=./data/feedback.sqlite

# Optional: set if hosting under a sub-path (e.g. /docs, /help)
# Leave blank for root deployments.
# PUBLIC_BASE_PATH=/docs

# Self-hosted Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_INDEX=eidentic_docs
MEILISEARCH_SEARCH_API_KEY=
MEILISEARCH_ADMIN_API_KEY=
